# .env.example — Copy to .env and fill in real values. Never commit .env files.

# MySQL (local / Docker)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# For run-migrations.sh (dev)
DB_HOST=localhost
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppassword
